# =============================================================================
# Karosale — Environment Variables
# Copy to .env.local for local dev. Set in Vercel per environment (Preview vs Production).
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → Project → Connection string (pooled)
# Preview: use Neon preview branch URL. Production: main branch pooled URL.
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/karosale?sslmode=require

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_PREVIEW=false
NODE_ENV=development

# --- Auth.js ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Same value as NEXTAUTH_SECRET (Auth.js v5 alias)
AUTH_SECRET=
# Production: https://karosale-in.vercel.app
NEXTAUTH_URL=http://localhost:3000
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Razorpay ---
# Dashboard: https://dashboard.razorpay.com/app/keys
# Preview: rzp_test_* keys only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Shiprocket ---
# https://app.shiprocket.in/
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- WhatsApp (Interakt) ---
# https://app.interakt.ai/
INTERAKT_API_KEY=
INTERAKT_ADMIN_PHONE=919999999999

# --- Email (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@karosale.com

# --- SMS OTP (Fast2SMS) ---
# https://www.fast2sms.com/
FAST2SMS_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Inngest ---
# https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Cloudflare R2 (S3-compatible) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=karosale-media
CLOUDFLARE_R2_PUBLIC_URL=https://media.karosale.com

# --- PostHog (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Seed (preview only — never true in production) ---
SEED_DATABASE=false

# =============================================================================
# CSR Organics (csrorganics) — Environment Variables
# Copy to .env.local for local dev. Set in Vercel per environment (Preview vs Production).
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → Project → Connection string (pooled)
# Preview: use Neon preview branch URL. Production: main branch pooled URL.
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/csrorganics?sslmode=require

# --- App ---
# Local: http://localhost:3000 | Vercel: use your deployment URL, e.g. https://<project>.vercel.app
# Vercel can also expose https://${VERCEL_URL} in server code; set NEXT_PUBLIC_APP_URL in project env for correct links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_PREVIEW=false
NODE_ENV=development

# --- Auth.js / NextAuth (v5) ---
# Generate: openssl rand -base64 32 — required for sessions, magic links, and Google OAuth state.
AUTH_SECRET=
# Legacy alias (optional if AUTH_SECRET is set)
NEXTAUTH_SECRET=
# Canonical app URL Auth.js uses for callbacks and magic-link emails. Must match how you open the app.
# Local: http://localhost:3000  |  Production: https://your-domain.com
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Optional: separate secret for signed wishlist share links (defaults to AUTH_SECRET / NEXTAUTH_SECRET).
WISHLIST_SHARE_SECRET=

# Google OAuth — use EITHER pair (Auth.js infers AUTH_GOOGLE_* automatically if you only set these):
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Legacy names (still supported):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client:
#   Authorized JavaScript origins: http://localhost:3000
#   Authorized redirect URIs:      http://localhost:3000/api/auth/callback/google
# (Replace host with production URL when deployed.)
#
# Show “Continue with Google” on /account (hidden by default). Set to true after OAuth is configured.
# NEXT_PUBLIC_GOOGLE_SIGNIN_ENABLED=true

# --- Email (Resend) — magic sign-in link + transactional mail ---
# https://resend.com/api-keys — required for "Email me a sign-in link" (also requires DATABASE_URL).
RESEND_API_KEY=
# Must be a sender you verified in Resend (or use onboarding@resend.dev for Resend's test domain).
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Razorpay ---
# Dashboard: https://dashboard.razorpay.com/app/keys
# Preview: rzp_test_* keys only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Shiprocket ---
# https://app.shiprocket.in/
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- WhatsApp (Interakt) ---
# https://app.interakt.ai/
INTERAKT_API_KEY=
INTERAKT_ADMIN_PHONE=919999999999

# --- SMS OTP (Fast2SMS) ---
# https://www.fast2sms.com/
FAST2SMS_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Inngest ---
# https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Cloudflare R2 (S3-compatible) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=csrorganics-media
CLOUDFLARE_R2_PUBLIC_URL=https://media.csrorganics.com

# --- PostHog (product analytics) ---
# https://posthog.com/ — create a project, copy Project API key
NEXT_PUBLIC_POSTHOG_KEY=
# EU cloud: https://eu.i.posthog.com | US cloud: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Business / tax (invoices & packing slips) ---
# Legal name on GST invoices; defaults to GRSOrganics if unset.
BUSINESS_LEGAL_NAME=GRSOrganics
# India GSTIN (15 characters). Replace placeholder when registered.
BUSINESS_GSTIN=32AAAAA0000A1Z5
BUSINESS_ADDRESS_LINE1=42, Palm Grove Avenue, Edappally
BUSINESS_ADDRESS_LINE2=Kochi, Kerala 682024
BUSINESS_ADDRESS_COUNTRY=India
# Text after “GSTIN (…)” on invoices/packing — default matches your GST = Gross Sales Tax wording.
BUSINESS_GST_STANDS_FOR=Gross Sales Tax

# --- Seed (preview only — never true in production) ---
SEED_DATABASE=false

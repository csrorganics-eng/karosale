# =============================================================================
# CSR Organics (csrorganics) — Environment Variables
# Copy to .env.local for local dev. Set in Vercel per environment (Preview vs Production).
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → Project → Connection string (pooled)
# Preview: use Neon preview branch URL. Production: main branch pooled URL.
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/csrorganics?sslmode=require
# Optional: explicit direct URL for drizzle-kit only (otherwise the config strips `-pooler` from DATABASE_URL automatically).
# DRIZZLE_DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/csrorganics?sslmode=require
# Neon: `npm run db:push` detects *.neon.tech and runs HTTP migrations (same as db:migrate). Force TCP drizzle-kit: DRIZZLE_KIT_PUSH=1
# Non-neon host but you want HTTP migrate from db:push: FORCE_NEON_HTTP_DB_PUSH=1

# --- App ---
# Local: http://localhost:3000 | Vercel: use your deployment URL, e.g. https://<project>.vercel.app
# Vercel can also expose https://${VERCEL_URL} in server code; set NEXT_PUBLIC_APP_URL in project env for correct links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_PREVIEW=false
NODE_ENV=development

# --- Auth.js / NextAuth (v5) ---
# Generate: openssl rand -base64 32 — required for sessions, magic links, and Google OAuth state.
AUTH_SECRET=
# Legacy alias (optional if AUTH_SECRET is set)
NEXTAUTH_SECRET=
# Canonical app URL Auth.js uses for callbacks and magic-link emails. Must match how you open the app.
# Local: http://localhost:3000  |  Production: https://your-domain.com
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Optional: separate secret for signed wishlist share links (defaults to AUTH_SECRET / NEXTAUTH_SECRET).
WISHLIST_SHARE_SECRET=

# Google OAuth — use EITHER pair (Auth.js infers AUTH_GOOGLE_* automatically if you only set these):
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Legacy names (still supported):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client:
#   Authorized JavaScript origins: http://localhost:3000
#   Authorized redirect URIs:      http://localhost:3000/api/auth/callback/google
# (Replace host with production URL when deployed.)
#
# Show “Continue with Google” on /account (hidden by default). Set to true after OAuth is configured.
# NEXT_PUBLIC_GOOGLE_SIGNIN_ENABLED=true

# --- Email (Resend) — magic sign-in link + transactional mail ---
# https://resend.com/api-keys — required for "Email me a sign-in link" (also requires DATABASE_URL).
RESEND_API_KEY=
# Sender: bare mailbox, OR a full header copied from another app, e.g. Acme <onboarding@resend.dev> (no extra wrapping).
# With onboarding@resend.dev, Resend only delivers to your Resend account email until you verify a domain: https://resend.com/domains
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional. Omit for "CSR Organics <mailbox>". Set empty (RESEND_FROM_DISPLAY_NAME=) for plain mailbox only, like Resend's minimal examples.
# RESEND_FROM_DISPLAY_NAME=

# --- Razorpay ---
# Dashboard: https://dashboard.razorpay.com/app/keys
# Preview: rzp_test_* keys only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret from: Dashboard → Account & Settings → Webhooks → [your endpoint] → Secret
# NOT the same as API Key Secret. Endpoint URL (production): https://YOUR_DOMAIN/api/webhooks/razorpay
# Subscribe at minimum to: payment.captured, payment.failed, payment.refunded
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Affiliate program ---
# Cookie sealing (falls back to AUTH_SECRET if unset). Generate: openssl rand -base64 32
AFFILIATE_COOKIE_SECRET=
# Optional override (default csro_affiliate_ref)
# AFFILIATE_COOKIE_NAME=csro_affiliate_ref
# Ops inbox for new applications + payout requests (Resend must be configured)
ADMIN_AFFILIATE_NOTIFICATION_EMAIL=
# RazorpayX payouts (separate from checkout keys). Webhook: POST /api/affiliate/webhook/razorpay
RAZORPAY_PAYOUT_KEY_ID=
RAZORPAY_PAYOUT_KEY_SECRET=
RAZORPAY_PAYOUT_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=

# --- Shiprocket ---
# https://app.shiprocket.in/
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- WhatsApp (Interakt) ---
# https://app.interakt.ai/
INTERAKT_API_KEY=
INTERAKT_ADMIN_PHONE=919999999999

# --- SMS OTP (Fast2SMS) ---
# https://www.fast2sms.com/
FAST2SMS_API_KEY=

# --- Shop chat & admin short copy (Groq → Cerebras → Gemini OpenAI-compat) ---
# Chat requires at least GROQ_API_KEY or CEREBRAS_API_KEY. Admin ai-copy can fall back to GEMINI_API_KEY alone.
# https://console.groq.com/keys | https://cloud.cerebras.ai/
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_CHAT_MODEL=llama-4-scout

# --- Google Gemini (semantic rerank, personalization profile — native API; also last resort for chat/copy via OpenAI-compat URL) ---
# https://aistudio.google.com/apikey — server-only; never NEXT_PUBLIC_*.
# On Vercel: a Team "Shared" variable linked to this project is injected like any other secret (same as GEMINI_API_KEY here).
# The app also accepts GOOGLE_GENERATIVE_AI_API_KEY or GOOGLE_AI_API_KEY if you prefer those names.
GEMINI_API_KEY=
# Optional. Default: gemini-2.5-flash; on 404 or rate-limit the client tries flash-lite then 2.0-flash.
# See https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.5-flash-lite
# After chat hits rate limits on every model in the chain, extra full-chain retries (default 1 → 2 tries). Max 5 extras.
# GEMINI_RATE_LIMIT_EXTRA_RETRIES=1
# Shop chat escalations (needs RESEND_API_KEY).
# CHAT_ESCALATION_EMAIL=you@example.com
# Optional: relax in-app rate limit (default dev 120/min, prod 72/min per browser session key).
# CHAT_RATE_LIMIT_MAX=200
# CHAT_RATE_LIMIT_WINDOW_MS=60000
# Max model↔tool rounds per shopper message (default 6).
# CHAT_MAX_TOOL_ROUNDS=6
# Optional: append text to the shop companion system prompt (e.g. blog or policy summary). Truncated server-side (~8k chars).
# SHOP_CHAT_COMPANION_NOTES=
#
# Product search semantic rerank (Gemini): default is Gemini-first; falls back to SQL/keyword order on timeout or rate limit.
# SEARCH_SEMANTIC_TIMEOUT_MS=12000
# After a search rerank hits quota/rate limits, skip Gemini for this many ms (default 45000).
# SEARCH_SEMANTIC_COOLDOWN_MS=45000
# Emergency: force keyword/SQL order only (true|1|yes).
# SEARCH_SEMANTIC_DISABLED=false

# --- OpenAI ---
OPENAI_API_KEY=

# --- Inngest ---
# https://app.inngest.com/ — App → Manage → Keys
# INNGEST_EVENT_KEY = "Event key" (used when the app calls inngest.send(), e.g. COD checkout).
# INNGEST_SIGNING_KEY = "Signing key" (used only to verify Inngest → your /api/inngest requests).
# Do not swap them; wrong key → 401 "Event key not found" on checkout.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Cloudflare R2 (S3-compatible) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=csrorganics-media
CLOUDFLARE_R2_PUBLIC_URL=https://media.csrorganics.com
# Used as a trusted host for marketing reference images (product packshots + optional event uploads).

# --- PostHog (product analytics) ---
# https://posthog.com/ — create a project, copy Project API key
NEXT_PUBLIC_POSTHOG_KEY=
# EU cloud: https://eu.i.posthog.com | US cloud: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Business / tax (invoices & packing slips) ---
# Legal name on GST invoices; defaults to GRSOrganics if unset.
BUSINESS_LEGAL_NAME=GRSOrganics
# India GSTIN (15 characters). Replace placeholder when registered.
BUSINESS_GSTIN=32AAAAA0000A1Z5
BUSINESS_ADDRESS_LINE1=42, Palm Grove Avenue, Edappally
BUSINESS_ADDRESS_LINE2=Kochi, Kerala 682024
BUSINESS_ADDRESS_COUNTRY=India
# Text after “GSTIN (…)” on invoices/packing — default matches your GST = Gross Sales Tax wording.
BUSINESS_GST_STANDS_FOR=Gross Sales Tax

# --- Pollinations (AI Marketing — Flux images via gen.pollinations.ai) ---
# Full step-by-step: docs/POLLINATIONS-MARKETING-IMAGES.md
# Keys: https://enter.pollinations.ai — use a secret key (sk_) only. Publishable (pk_) keys are deprecated
# on Pollinations; this app uses HMAC-signed same-origin URLs instead of exposing keys in the browser.
#
# POLLINATIONS_API_KEY — paste your SECRET key (starts with sk_). Server-only.
# Used as Authorization: Bearer … when calling gen.pollinations.ai (including the signed image proxy).
POLLINATIONS_API_KEY=
#
# Signing for marketing image URLs uses AUTH_SECRET or NEXTAUTH_SECRET (same as Auth.js).
#
# Optional — comma- or space-separated extra hostnames allowed as Pollinations *reference* image URLs
# (product packshots). Defaults include *.r2.dev, *.cloudflarestorage.com, *.amazonaws.com and your
# NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_MEDIA_URL hosts.
# MARKETING_REF_IMAGE_HOSTS=cdn.example.com,images.example.com

# --- Meta / Facebook (AI Marketing Studio — Graph API publishing) ---
# Create a free app at https://developers.facebook.com — add Facebook Login + Instagram Graph API.
# Valid OAuth redirect URI: {NEXT_PUBLIC_APP_URL}/api/admin/marketing/social/connect/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Optional — 32+ char random hex; defaults to AUTH_SECRET for encrypting stored Page tokens.
# SOCIAL_TOKEN_ENCRYPTION_KEY=

# --- WhatsApp Business Cloud API (optional paid upgrade; wa.me links work with no config) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# =============================================================================
# SEO & Analytics (optional — see docs/SEO-IMPLEMENTATION.md)
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://csrorganics.com
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_OG_DEFAULT_IMAGE=
NEXT_PUBLIC_TWITTER_SITE=@csrorganics
NEXT_PUBLIC_TWITTER_CREATOR=@csrorganics
AUDIT_SECRET=
DEPLOY_WEBHOOK_SECRET=

# --- Seed (preview only — never true in production) ---
SEED_DATABASE=false


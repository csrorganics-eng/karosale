# EXPO_PUBLIC_API_ORIGIN = Next.js server (required)
# Local device + PC: http://192.168.x.x:3000
# Production API: https://your-domain.com
EXPO_PUBLIC_API_ORIGIN=http://localhost:3000

# Razorpay key exposed to the mobile app (public — starts with rzp_test_ or rzp_live_)
# Get from: https://dashboard.razorpay.com/app/keys
# Sandbox: use rzp_test_* for testing
# Production: use rzp_live_*
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
